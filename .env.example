# Agent Hub — 环境变量配置
#
# 复制本文件为 .env，填入实际 token 后使用
# cp .env.example .env

# 龙虾小助理 (OpenClaw Gateway)
AUTH_LOBSTER_ASSISTANT=Bearer <your-token-here>

# 龙虾专家 (OpenClaw Gateway)
AUTH_EXPERT=Bearer <your-token-here>

# Hermes 大主管 (Hermes Agent API, port 8642)
AUTH_HERMES_MAIN=Bearer <your-token-here>

# Hermes 专家 (Hermes Agent API, port 8643)
AUTH_HERMES_EXPERT_DEEPSEEK=Bearer <your-token-here>
